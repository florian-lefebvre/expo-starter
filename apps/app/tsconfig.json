{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"paths": {
			"@/*": ["./src/*"],
			"@/assets/*": ["./assets/*"]
		},
		"types": ["node"],
		"verbatimModuleSyntax": true
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
	],
	"exclude": ["example"]
}
